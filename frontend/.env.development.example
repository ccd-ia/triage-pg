# Copy to `.env.development` to override the API client's data source.
#
# By default (no env file) the client uses the local fixture in dev mode, so
# `npm run dev` renders the dashboard standalone with no backend. At integration
# time, set VITE_USE_FIXTURE=0 to hit the real /api endpoints through the Vite
# proxy (-> http://localhost:8000, see vite.config.ts).
VITE_USE_FIXTURE=1
