# Managed PostgreSQL with IAM database authentication (ADR-0004): per-project PG users get
# `GRANT rds_iam` (runbook step — never Terraform, which owns the CLUSTER, not the projects).
# Databases-per-project are created by `triage project create` (ADR-0002).

resource "aws_db_subnet_group" "triage" {
  name       = "${var.name_prefix}-db"
  subnet_ids = var.private_subnet_ids
}

resource "aws_security_group" "rds" {
  name        = "${var.name_prefix}-rds"
  description = "PostgreSQL: Batch jobs + (optionally) operator CIDRs"
  vpc_id      = var.vpc_id

  ingress {
    description     = "Batch job containers (IAM-token auth, ADR-0004)"
    from_port       = 5432
    to_port         = 5432
    protocol        = "tcp"
    security_groups = [aws_security_group.batch_jobs.id]
  }

  dynamic "ingress" {
    for_each = length(var.operator_cidr_blocks) > 0 ? [1] : []
    content {
      description = "Operator access (bootstrap, dashboards, triage project create)"
      from_port   = 5432
      to_port     = 5432
      protocol    = "tcp"
      cidr_blocks = var.operator_cidr_blocks
    }
  }

  egress {
    from_port   = 0
    to_port     = 0
    protocol    = "-1"
    cidr_blocks = ["0.0.0.0/0"]
  }
}

# The master password is generated by RDS and kept in Secrets Manager (bootstrap-only use);
# nothing in triage-pg ever stores it — day-to-day connections are IAM tokens (ADR-0004).
resource "aws_db_instance" "triage" {
  identifier                          = "${var.name_prefix}-pg"
  engine                              = "postgres"
  engine_version                      = var.rds_engine_version
  instance_class                      = var.rds_instance_class
  allocated_storage                   = var.rds_allocated_storage_gb
  storage_encrypted                   = true
  db_name                             = "registry" # the ADR-0002 control plane; project DBs via `triage project create`
  username                            = var.rds_master_username
  manage_master_user_password         = true
  iam_database_authentication_enabled = true
  db_subnet_group_name                = aws_db_subnet_group.triage.name
  vpc_security_group_ids              = [aws_security_group.rds.id]
  multi_az                            = false
  publicly_accessible                 = false
  deletion_protection                 = var.rds_deletion_protection
  skip_final_snapshot                 = var.rds_skip_final_snapshot
  final_snapshot_identifier           = var.rds_skip_final_snapshot ? null : "${var.name_prefix}-pg-final"
  backup_retention_period             = 7
}
